PORT=3001

# Database (same pattern as whatsapp-claims-poc)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_handbook
DB_USER=postgres
DB_PASSWORD=your_password

# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# RAG
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=160
RAG_MATCH_LIMIT=5
RAG_HISTORY_LIMIT=6
RAG_MIN_EMBEDDING_SCORE=0.28
RAG_MIN_LEXICAL_SCORE=0.5

# Handbook PDF path for npm run ingest
HANDBOOK_PATH=C:\\Users\\User\\Downloads\\20260606152537803.pdf
HANDBOOK_TITLE=D'Starlington Property Handbook
HANDBOOK_PAGES_DIR=data/handbook-pages

# Groq Configuration (primary - fastest, LPU-backed inference)
USE_GROQ=true
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional tuning:
# GROQ_TEMPERATURE=0.2
# GROQ_MAX_TOKENS=700

# Nvidia Configuration
USE_NVIDIA=true
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# OpenRouter Configuration
USE_OPENROUTER=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Public application URL for serving PDF page links on cPanel (e.g. https://yourdomain.com)
PUBLIC_URL=
